# AdsPower 专项拒绝规则。
# 生成来源：rules/app/adspower.txt
# 请修改主清单，不要直接编辑本文件。

# 隐私追踪与客服阻断
# 拦截 Sentry 崩溃与异常上报
DOMAIN,sentry.adspower.com
DOMAIN,sentry.adspower.net

# 拦截内部运行日志与遥测打点
DOMAIN,logger.adspower.com
DOMAIN,logger.adspower.net

# 拦截微软 Clarity 用户交互行为热力图追踪
DOMAIN-SUFFIX,clarity.ms

# 一键拦截 SaleSmartly 客服系统的所有子域名（聊天流、静态资源、长连接）
DOMAIN-SUFFIX,salesmartly.com

# 拦截图片静态资源域名树（覆盖 img 主机及其下级子域）
DOMAIN-SUFFIX,img.adspower.com
DOMAIN-SUFFIX,img.adspower.net

# 版本控制与内核/插件下载
DOMAIN,download.adspower.com
DOMAIN,download.adspower.net
DOMAIN,version.adspower.com
DOMAIN,version.adspower.net

# 国内 SaaS 账号基础设施
DOMAIN,api.saasbase.cn

# 可安全阻断的 AdsPower 核心端点
# 禁用后仍可正常登录并打开指纹浏览器
DOMAIN,sys.adspower.com
DOMAIN,sys.adspower.net
DOMAIN,api.adspower.com
DOMAIN,api.adspower.net
DOMAIN,api.adspowerapp.com

# 拦截 appdo 前缀动态子域名（兼容 Surge / Mihomo）
DOMAIN-WILDCARD,appdo*.adspower.com
DOMAIN-WILDCARD,appdo*.adspower.net

# 拦截环境状态与用户资料更新接口，阻断本地状态回传
URL-REGEX,^https?://api-global\.adspower\.com/client/fbcc-user-v2/update
URL-REGEX,^https?://api-global\.adspower\.net/client/fbcc-user-v2/update
URL-REGEX,^https?://api-global\.adspower\.com/fbcc/user/update-user-info
URL-REGEX,^https?://api-global\.adspower\.net/fbcc/user/update-user-info

# 拦截临时对象存储上传凭证下发，阻断云端写入授权
URL-REGEX,^https?://api-global\.adspower\.com/client/oss-sts/get-upload-config
URL-REGEX,^https?://api-global\.adspower\.net/client/oss-sts/get-upload-config

# 拦截 storage_cache 上传链路，阻断 localStorage 与 IndexedDB 等缓存外传
URL-REGEX,^https?://.*\.aliyuncs\.com/storage_cache/
URL-REGEX,^https?://.*\.amazonaws\.com/storage_cache/
URL-REGEX,^https?://.*\.adspower\.com/storage_cache/
URL-REGEX,^https?://.*\.adspower\.net/storage_cache/
